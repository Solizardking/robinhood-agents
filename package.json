{
  "name": "@cheshire-terminal/robinhood-agents",
  "version": "0.1.0",
  "description": "Dual-chain agent identity SDK and guarded ERC-8004 registry tooling for Robinhood Chain and Solana",
  "type": "module",
  "sideEffects": false,
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Solizardking/robinhood-agents.git"
  },
  "homepage": "https://github.com/Solizardking/robinhood-agents#readme",
  "bugs": {
    "url": "https://github.com/Solizardking/robinhood-agents/issues"
  },
  "keywords": [
    "ai-agents",
    "erc-8004",
    "evm",
    "robinhood-chain",
    "solana",
    "svm",
    "metaplex"
  ],
  "bin": {
    "robinhood-agents": "./src/cli.js"
  },
  "exports": {
    ".": "./src/index.js",
    "./deployments": "./src/deployments.js",
    "./deployments/mainnet-4663": "./deployments/agent-registries-mainnet-4663.json",
    "./deployments/testnet-46630": "./deployments/agent-registries-testnet-46630.json",
    "./package.json": "./package.json"
  },
  "scripts": {
    "test": "node --test test/*.test.js deploy/test/*.test.cjs",
    "check": "node --check src/index.js && node --check src/deployments.js && node --check src/cli.js && node --check deploy/scripts/deployment-safety.cjs && npm test",
    "setup:solidity": "forge install foundry-rs/forge-std@v1.9.6 --no-git --shallow",
    "test:solidity": "forge test -vv",
    "pack:check": "npm pack --dry-run"
  },
  "engines": {
    "node": ">=18.18"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "dependencies": {
    "viem": "^2.38.0"
  },
  "files": [
    "src",
    "contracts",
    "deploy",
    "deployments",
    "skills",
    "examples",
    "assets",
    "test",
    ".env.example",
    "foundry.toml",
    "remappings.txt",
    "README.md",
    "LICENSE"
  ]
}
