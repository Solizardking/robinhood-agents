{
  "name": "cheshire-terminal-agents",
  "version": "1.44.1",
  "description": "Cheshire Terminal Agents — dual-chain identity forge (Robinhood Chain EVM + Solana SVM) plus production DeFi/Solana agent catalog, schema, and locales for cheshireterminal.ai/agents",
  "type": "module",
  "sideEffects": false,
  "license": "MIT",
  "author": "Cheshire Terminal <operators@cheshireterminal.ai>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Solizardking/Cheshire-Terminal-Agents.git"
  },
  "homepage": "https://cheshireterminal.ai/agents",
  "bugs": {
    "url": "https://github.com/Solizardking/Cheshire-Terminal-Agents/issues"
  },
  "keywords": [
    "cheshire-terminal",
    "cheshire-terminal-agents",
    "ai-agents",
    "defi",
    "erc-8004",
    "evm",
    "robinhood-chain",
    "solana",
    "svm",
    "metaplex",
    "clawd",
    "mcp"
  ],
  "bin": {
    "cheshire-terminal-agents": "./src/cli.js",
    "ct-agents": "./src/cli.js",
    "robinhood-agents": "./src/cli.js"
  },
  "exports": {
    ".": "./src/index.js",
    "./agentCatalog": "./src/agentCatalog.js",
    "./deployments": "./src/deployments.js",
    "./deployments/mainnet-4663": "./deployments/agent-registries-mainnet-4663.json",
    "./deployments/testnet-46630": "./deployments/agent-registries-testnet-46630.json",
    "./schema/Cheshire_agent_schema.json": "./schema/Cheshire_agent_schema.json",
    "./package.json": "./package.json"
  },
  "scripts": {
    "import:agents": "node scripts/import-agents.mjs",
    "agents:import": "node scripts/import-agents.mjs",
    "agents:validate": "node --test test/agents-catalog.test.js",
    "agents:list": "node -e \"import('./src/agentCatalog.js').then(m=>console.log(m.listCatalogIdentifiers().join('\\n')))\"",
    "validate:agents": "node --test test/agents-catalog.test.js",
    "test": "node --test test/*.test.js deploy/test/*.test.cjs",
    "check": "node --check src/index.js && node --check src/deployments.js && node --check src/agentCatalog.js && node --check src/cli.js && node --check deploy/scripts/deployment-safety.cjs && npm test",
    "setup:solidity": "forge install foundry-rs/forge-std@v1.9.6 --no-git --shallow",
    "test:solidity": "forge test -vv",
    "pack:check": "npm pack --dry-run",
    "prepublishOnly": "npm test"
  },
  "engines": {
    "node": ">=18.18"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "dependencies": {
    "viem": "^2.38.0"
  },
  "files": [
    "src",
    "agents",
    "locales",
    "schema",
    "scripts/import-agents.mjs",
    "contracts",
    "deploy/script",
    "deploy/scripts",
    "deploy/test",
    "deployments",
    "skills",
    "examples",
    "assets",
    "test",
    ".env.example",
    "foundry.toml",
    "remappings.txt",
    "README.md",
    "LICENSE"
  ]
}
