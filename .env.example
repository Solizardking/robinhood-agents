# Required for every dry-run or broadcast. Use a throwaway, gas-only deployer.
PRIVATE_KEY=0xREPLACE_WITH_32_BYTE_HEX_PRIVATE_KEY
EXPECTED_CHAIN_ID=46630
RH_RPC_URL=https://rpc.testnet.chain.robinhood.com

# Required only with --broadcast. The wrapper rejects broadcasts for a chain
# that already has a canonical manifest in deployments/.
DEPLOYMENT_CONFIRMATION=DEPLOY ROBINHOOD TESTNET 46630

# Additional mainnet-only controls:
# RH_RPC_IS_QUOTA_BACKED=1
# DEPLOYMENT_AUDIT_SHA256=0xREPLACE_WITH_NONZERO_32_BYTE_SHA256
